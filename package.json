{
  "name": "prisma-extension-redis",
  "version": "3.4.0",
  "description": "Extensive Prisma extension designed for efficient caching and cache invalidation using Redis and Dragonfly Databases",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yxx4c/prisma-extension-redis.git"
  },
  "homepage": "https://github.com/yxx4c/prisma-extension-redis",
  "bugs": "https://github.com/yxx4c/prisma-extension-redis/issues",
  "author": {
    "name": "caxxy",
    "email": "mail.yxx4c+npm@gmail.com",
    "url": "https://github.com/yxx4c"
  },
  "keywords": [
    "prisma",
    "redis",
    "dragonfly",
    "cache",
    "cache-invalidation",
    "cache-manager",
    "caching",
    "auto-caching",
    "promise-coalescing",
    "performance",
    "middleware",
    "database-cache",
    "uncache",
    "read-ahead",
    "prisma-extension",
    "prisma-redis-cache",
    "prisma-redis-extension",
    "prisma-redis-middleware",
    "prisma-cache-extension",
    "prisma-query-cache",
    "prisma-caching",
    "prisma-extension-dragonfly",
    "prisma-middleware",
    "caching-middleware"
  ],
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "typesVersions": {
    "*": {}
  },
  "files": [
    "dist/**/*",
    "package.json",
    "CHANGELOG.md",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "biome": "biome",
    "dev": "tsup --watch",
    "test": "bun test",
    "check": "biome check",
    "check:write": "biome check --write",
    "prisma:migrate": "bunx prisma migrate dev --config ./test/prisma/prisma.config.ts",
    "prisma:generate": "bunx prisma generate --config ./test/prisma/prisma.config.ts",
    "pretest": "bun run prisma:migrate && bun run prisma:generate",
    "posttest": "bun run check",
    "release": "semantic-release"
  },
  "devDependencies": {
    "@amanda-mitchell/semantic-release-npm-multiple": "^3.17.0",
    "@biomejs/biome": "^2.5.3",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@types/bun": "^1.3.14",
    "@types/node": "^25.9.5",
    "dotenv": "^17.4.2",
    "prisma": "^7.8.0",
    "semantic-release": "^25.0.5",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "iovalkey": "^0.3.3",
    "object-code": "^2.0.0",
    "promise-coalesce": "^1.5.0"
  }
}
